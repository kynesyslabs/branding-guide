{
  "$meta": {
    "name": "Demos Network Brand Tokens",
    "mode": "dark-first",
    "sources": ["demos.network", "scan.demos.network", "faucet.demos.sh", "kynesys.xyz"]
  },
  "color": {
    "brand": {
      "violet": "#7c3aed",
      "violet-strong": "#a78bfa",
      "violet-soft": "#7c3aed1f",
      "violet-border": "#7c3aed4d",
      "green": "#34d399",
      "green-strong": "#10b981",
      "green-soft": "#10b9811f",
      "green-border": "#10b9814d",
      "cyan": "#06b6d4",
      "cyan-strong": "#22d3ee",
      "cyan-soft": "#06b6d41f",
      "cyan-border": "#06b6d44d"
    },
    "bg": {
      "letterbox": "#06060a",
      "primary": "#08080a",
      "base": "#0a0a0a",
      "secondary": "#0e0e11",
      "card": "#111113",
      "card-hover": "#16161a",
      "hover": "#1d1d22",
      "tinted": "#13121f"
    },
    "glass": {
      "card": "#14141aa6",
      "card-hover": "#1a1a22bf",
      "panel": "#0e0e11cc",
      "border": "#ffffff1f"
    },
    "text": {
      "primary": "#f4f4f5",
      "secondary": "#b4b4bb",
      "muted": "#8a8a93",
      "faint": "#7c7c87",
      "inverse": "#0a0a0a"
    },
    "border": {
      "subtle": "#ffffff0e",
      "default": "#ffffff17",
      "strong": "#ffffff26",
      "hover": "#ffffff29"
    },
    "status": {
      "success": "#34d399",
      "success-soft": "#10b9811f",
      "success-muted": "#34d39921",
      "warning": "#fbbf24",
      "warning-soft": "#f59e0b1f",
      "warning-muted": "#fbbf2421",
      "error": "#f87171",
      "error-soft": "#ef44441f",
      "error-muted": "#f8717121",
      "info": "#818cf8",
      "info-soft": "#3b82f61f",
      "info-muted": "#818cf824"
    },
    "focus-ring": "#a78bfacc"
  },
  "gradient": {
    "glow-hero": "radial-gradient(60% 50% at 50% 35%, #7c3aed1a 0%, #7c3aed00 65%)",
    "glow-ambient": "radial-gradient(520px at 50% 30%, #7c3aed1a, #7c3aed08 35%, #00000000 60%)",
    "vignette": "radial-gradient(75% 55%, #00000000 0%, #000000b3 100%)"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
    "display": "\"Plus Jakarta Sans\", \"Inter\", system-ui, -apple-system, sans-serif",
    "mono": "\"SF Mono\", \"Fira Code\", \"Source Code Pro\", \"Fira Mono\", Menlo, Monaco, monospace",
    "weight": { "normal": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "fontSize": {
    "caption": "0.75rem",
    "label": "0.875rem",
    "base": "1rem",
    "lg": "1.125rem",
    "xl": "1.25rem",
    "2xl": "1.5rem",
    "3xl": "1.875rem",
    "hero": "3rem",
    "fluid-hero": "clamp(1.375rem, 0.9rem + 2.4vw, 2.5rem)",
    "fluid-h2": "clamp(2rem, 1.2rem + 4vw, 4.25rem)",
    "fluid-h3": "clamp(1.25rem, 1rem + 1.4vw, 2rem)",
    "fluid-body": "clamp(0.95rem, 0.85rem + 0.55vw, 1.3rem)"
  },
  "lineHeight": { "tight": 1.1, "snug": 1.35, "normal": 1.5, "body": 1.6 },
  "letterSpacing": { "tight": "-0.02em", "wide": "0.12em" },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px",
    "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px",
    "20": "80px", "24": "96px", "32": "128px"
  },
  "radius": {
    "sm": "4px", "md": "6px", "lg": "8px", "button": "10px",
    "xl": "12px", "card": "14px", "2xl": "16px", "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px #0006",
    "md": "0 0 0 1px #ffffff0e, 0 2px 6px #0006",
    "lg": "0 0 0 1px #ffffff0e, 0 8px 24px #00000080"
  },
  "blur": { "sm": "8px", "md": "12px", "2xl": "40px" },
  "motion": {
    "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
    "duration-fast": "150ms",
    "duration-base": "250ms"
  }
}
